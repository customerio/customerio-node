{
  "name": "customerio-node",
  "description": "A node client for the Customer.io event API. http://customer.io",
  "version": "4.5.1",
  "author": "Customer.io (https://customer.io)",
  "contributors": [
    "Alvin Crespo (https://github.com/alvincrespo)",
    "Jeff Escalante (https://github.com/jescalan)",
    "Artem Ivanov (https://github.com/ivanovart)",
    "Nuno Sousa (https://github.com/nunofgs)"
  ],
  "ava": {
    "verbose": true,
    "files": [
      "test/**/*.js"
    ]
  },
  "c8": {
    "exclude": [
      "test/**",
      "dist/**",
      "coverage/**",
      "examples/**"
    ],
    "reporter": [
      "text"
    ],
    "check-coverage": true,
    "branches": 100,
    "lines": 100,
    "functions": 100,
    "statements": 100
  },
  "bugs": "https://github.com/customerio/customerio-node/issues",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "ava": "^6.4.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sinon": "^19.0.5",
    "typescript": "^6.0.3"
  },
  "homepage": "https://github.com/customerio/customerio-node",
  "keywords": [
    "customerio",
    "node"
  ],
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "files": [
    "index.js",
    "lib",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "repository": "customerio/customerio-node",
  "scripts": {
    "test": "c8 ava",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,json,md,yml,yaml}": "prettier --write",
    "*.js": "eslint --fix"
  }
}
