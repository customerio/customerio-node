{
  "name": "customerio-node",
  "description": "A node client for the Customer.io event API. http://customer.io",
  "version": "4.5.0",
  "author": "Customer.io (https://customer.io)",
  "contributors": [
    "Alvin Crespo (https://github.com/alvincrespo)",
    "Jeff Escalante (https://github.com/jescalan)",
    "Artem Ivanov (https://github.com/ivanovart)",
    "Nuno Sousa (https://github.com/nunofgs)"
  ],
  "ava": {
    "verbose": true,
    "extensions": {
      "ts": "commonjs"
    },
    "require": [
      "ts-node/register"
    ]
  },
  "nyc": {
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "exclude": [
      "**/*.d.ts",
      "coverage/",
      "test/"
    ],
    "reporter": [
      "text"
    ],
    "cache": false,
    "check-coverage": true,
    "branches": 100,
    "lines": 100,
    "functions": 100,
    "statements": 100
  },
  "bugs": "https://github.com/customerio/customerio-node/issues",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.0",
    "ava": "^6.2.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "nyc": "^18.0.0",
    "prettier": "^3.3.0",
    "sinon": "^19.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "homepage": "https://github.com/customerio/customerio-node",
  "keywords": [
    "customerio",
    "node"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": "customerio/customerio-node",
  "scripts": {
    "test": "nyc ava",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "version": "node update-version.js"
  }
}
