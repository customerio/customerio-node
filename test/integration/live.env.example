# Live test credentials. Copy to `live.env`, fill in, and run:
#
#   set -a && source test/integration/live.env && set +a
#   npm run test:live:all
#
# `live.env` is gitignored. Point these at a THROWAWAY personal/test workspace,
# never production: the suites write profiles, fire events, and (in live.ts)
# delete/merge profiles.

# --- Required to run anything ---
CIO_LIVE=1

# --- Track + App API suite (test/integration/live.ts) ---
# Track API: Settings -> API Credentials -> Tracking API Keys
CIO_SITE_ID=
CIO_API_KEY=
# App API bearer token: Settings -> API Credentials -> App API Keys
CIO_APP_KEY=

# --- Pipelines suite (test/integration/v5-live.ts) ---
# Data Pipelines source write key: Data Pipelines -> Sources -> (your source)
CIO_PIPELINES_WRITE_KEY=

# --- Common ---
# "us" (default) or "eu"
CIO_REGION=us

# --- Optional: gate individual send/broadcast/export tests in live.ts ---
# Each is skipped unless set. These need workspace-specific message IDs.
CIO_TEST_EMAIL_RECIPIENT=
CIO_TEST_TRANSACTIONAL_ID=
CIO_TEST_SMS_RECIPIENT=
CIO_TEST_SMS_TRANSACTIONAL_ID=
CIO_TEST_PUSH_TRANSACTIONAL_ID=
CIO_TEST_PUSH_DEVICE_ID=
CIO_TEST_INAPP_TRANSACTIONAL_ID=
CIO_TEST_INBOX_TRANSACTIONAL_ID=
CIO_TEST_BROADCAST_ID=
CIO_TEST_NEWSLETTER_ID=
